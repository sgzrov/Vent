{
  "name": "@vent-hq/livekit",
  "version": "0.2.0",
  "type": "module",
  "description": "Vent helper for forwarding LiveKit Agents SDK observability",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepack": "pnpm clean && pnpm build"
  },
  "keywords": [
    "vent",
    "livekit",
    "voice",
    "agents",
    "observability"
  ],
  "license": "MIT",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vent-hq/vent.git",
    "directory": "packages/livekit"
  },
  "homepage": "https://venthq.dev",
  "peerDependencies": {
    "@livekit/agents": "^1.0.0",
    "@livekit/rtc-node": "^0.13.0"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
