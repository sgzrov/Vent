{
  "name": "vent",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "db:generate": "pnpm --filter @vent/db generate",
    "db:migrate": "pnpm --filter @vent/db migrate",
    "deploy:api": "fly deploy . --config apps/api/fly.toml --dockerfile apps/api/Dockerfile --remote-only",
    "deploy:worker": "fly deploy . --config apps/worker/fly.toml --dockerfile apps/worker/Dockerfile --remote-only",
    "deploy:dashboard": "cd apps/dashboard && fly deploy --remote-only",
    "deploy:all": "pnpm deploy:api & pnpm deploy:worker & pnpm deploy:dashboard & wait"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^20.0.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "ioredis": "5.9.3"
    }
  }
}
