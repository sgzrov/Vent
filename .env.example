# Database + Redis
DATABASE_URL=postgres://user:password@host:5432/postgres?sslmode=require
REDIS_URL=rediss://default:password@host:6379

# AI / voice providers
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
HUME_API_KEY=

# WorkOS auth
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3001/auth/callback
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=

# Platform credential encryption + worker callbacks
# Generate PLATFORM_CONNECTIONS_MASTER_KEY with: openssl rand -hex 32
PLATFORM_CONNECTIONS_MASTER_KEY=
RUNNER_CALLBACK_SECRET=
RUNNER_PUBLIC_HOST=localhost
RUNNER_LISTEN_PORT=8443

# Cloudflare R2 / S3 for artifact storage (recordings, audio)
S3_ACCESS_KEY_ID=
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=auto
S3_SECRET_ACCESS_KEY=

# Public URLs
DASHBOARD_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3000
