# Database
DATABASE_URL=postgres://user:password@localhost:5432/voiceci

# Redis (Upstash)
REDIS_URL=redis://localhost:6379

# Object Storage (S3-compatible / R2)
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
S3_BUCKET=voiceci-bundles
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto

# Fly Machines API
FLY_API_TOKEN=

# Runner
RUNNER_CALLBACK_SECRET=change-me-to-a-random-secret

# API
API_URL=https://voiceci-api.fly.dev

# Dashboard
NEXT_PUBLIC_API_URL=https://voiceci-api.fly.dev
DASHBOARD_URL=https://voiceci-dashboard.fly.dev

# WorkOS Auth
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=
NEXT_PUBLIC_WORKOS_REDIRECT_URI=

# ── Voice Testing ─────────────────────────────────────────────────────────────

# Deepgram (TTS + STT)
DEEPGRAM_API_KEY=

# Twilio (SIP/Phone adapter)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# LiveKit (WebRTC adapter)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
